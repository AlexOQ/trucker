{
  "name": "ets2-trucker-advisor",
  "version": "0.1.0",
  "description": "Euro Truck Simulator 2 trailer set optimizer",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:frontend": "vite",
    "build": "tsc",
    "build:frontend": "vite build",
    "preview": "vite preview",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "export": "tsx scripts/export-data.ts",
    "test": "vitest run",
    "parse-saves": "node scripts/parse-saves.cjs",
    "defs-query": "node scripts/defs-query.cjs",
    "gen:data-coverage": "tsx scripts/gen-data-coverage.ts",
    "lint": "tsc --noEmit -p tsconfig.lint.json",
    "lint:fix": "tsc --noEmit -p tsconfig.lint.json",
    "format": "prettier --write src/frontend/"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@trucky/sii-decrypt-ts": "^1.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-unsanitized": "^4.1.4",
    "express": "^4.18.2",
    "jsdom": "^29.1.1",
    "kysely": "^0.28.17",
    "pg": "^8.11.3",
    "playwright": "^1.58.0",
    "prettier": "^3.8.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^3.4.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "qs": "^6.15.2"
  }
}
